# OpenAI API key used for GPT models
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API key used for Gemini models
GEMINI_API_KEY=your_gemini_api_key_here

# Optional Gemini model override
GEMINI_MODEL=gemini-2.5-flash

# SerpAPI key used for Google search results
SERPAPI_KEY=your_serpapi_key_here

# Redis URL used for response caching
REDIS_URL=redis://localhost:6379

# SQLite database path for cost logs and long-term memory
DB_PATH=memory.db

# Path where FAISS index and document metadata are persisted
VECTOR_STORE_PATH=./faiss_index

# Default high-capability model for complex tasks
DEFAULT_MODEL=gemini-2.5-flash

# Fast low-cost model for simple tasks
FAST_MODEL=gemini-2.5-flash

# Maximum number of reflection loops in orchestrator
MAX_REFLECTION_ITERATIONS=3

# Minimum critic score required to stop retrying
REFLECTION_SCORE_THRESHOLD=0.8

# Cache time-to-live in seconds for cached LLM responses
CACHE_TTL_SECONDS=3600
